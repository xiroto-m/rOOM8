rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email.lower() == "hiroto.mizutani@gmail.com" || 
         request.auth.token.email.lower() == "taku448@gmail.com") &&
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATIONS ---
    function isValidEvent(data) {
      return data.keys().hasAll(['date', 'time', 'locationName', 'address', 'access', 'fee', 'googleMapEmbedUrl', 'order', 'updatedAt'])
        && data.date is string && data.date.size() <= 100
        && data.time is string && data.time.size() <= 100
        && data.locationName is string && data.locationName.size() <= 200
        && data.address is string && data.address.size() <= 300
        && data.access is string && data.access.size() <= 300
        && data.fee is string && data.fee.size() <= 100
        && data.googleMapEmbedUrl is string && data.googleMapEmbedUrl.size() <= 1000
        && (!data.keys().hasAny(['youtubeUrl']) || (data.youtubeUrl is string && data.youtubeUrl.size() <= 1000))
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 10000))
        && (!data.keys().hasAny(['title']) || (data.title is string && data.title.size() <= 200))
        && (!data.keys().hasAny(['likesCount']) || data.likesCount is number)
        && data.order is number
        && data.updatedAt is timestamp;
    }

    function isValidLike(data, likeId) {
      return data.keys().hasAll(['ip', 'eventId', 'createdAt'])
        && data.ip is string && data.ip.size() <= 64
        && likeId == data.ip
        && data.eventId is string && data.eventId.size() <= 128
        && data.createdAt == request.time;
    }

    function isValidVisit(data) {
      return data.keys().hasAll(['deviceId', 'ip', 'date', 'deviceType', 'userAgent', 'timestamp'])
        && data.deviceId is string && data.deviceId.size() <= 128
        && data.ip is string && data.ip.size() <= 64
        && data.date is string && data.date.size() <= 10
        && data.deviceType in ['mobile', 'desktop']
        && data.timestamp is timestamp
        && (!data.keys().hasAny(['duration']) || data.duration is number)
        && (!data.keys().hasAny(['maxScrollDepth']) || data.maxScrollDepth is number)
        && (!data.keys().hasAny(['sectionsReached']) || data.sectionsReached is list)
        && (!data.keys().hasAny(['referrer']) || data.referrer is string)
        && (!data.keys().hasAny(['lastActive']) || data.lastActive is timestamp)
        // Mobile detailed fields
        && (!data.keys().hasAny(['language']) || data.language is string)
        && (!data.keys().hasAny(['screenWidth']) || data.screenWidth is number)
        && (!data.keys().hasAny(['screenHeight']) || data.screenHeight is number)
        && (!data.keys().hasAny(['devicePixelRatio']) || data.devicePixelRatio is number)
        && (!data.keys().hasAny(['orientation']) || data.orientation is string)
        && (!data.keys().hasAny(['connectionType']) || data.connectionType is string);
    }

    function isValidAction(data) {
      return data.keys().hasAll(['actionType', 'deviceId', 'date', 'timestamp'])
        && data.actionType is string && data.actionType.size() <= 100
        && data.deviceId is string && data.deviceId.size() <= 128
        && data.date is string && data.date.size() <= 10
        && data.timestamp is timestamp;
    }

    function isValidFeedback(data) {
      return data.keys().hasAll(['rating', 'comment', 'deviceId', 'timestamp'])
        && data.rating is number && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 5000
        && data.deviceId is string && data.deviceId.size() <= 128
        && data.timestamp is timestamp;
    }

    function isValidGalleryImage(data) {
      return data.keys().hasAll(['url', 'createdAt', 'order'])
        && data.url is string && data.url.size() <= 1048000
        && data.createdAt is number
        && data.order is number;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'currency', 'status', 'createdAt', 'order', 'updatedAt'])
        && data.name is string && data.name.size() <= 200
        && data.price is number
        && data.currency is string && data.currency.size() <= 10
        && data.status in ['active', 'sold_out', 'hidden']
        && data.createdAt is string
        && data.order is number
        && data.updatedAt is timestamp
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 2000))
        && (!data.keys().hasAny(['imageUrl']) || (data.imageUrl is string && data.imageUrl.size() <= 2000000))
        && (!data.keys().hasAny(['stripePriceId']) || (data.stripePriceId is string && data.stripePriceId.size() <= 200));
    }

    function isValidCreatorCard(data) {
      return data.keys().hasAll(['name', 'specialty', 'bio', 'createdAt'])
        && data.name is string && data.name.size() <= 200
        && data.specialty is string && data.specialty.size() <= 200
        && data.bio is string && data.bio.size() <= 2000
        && data.createdAt is timestamp
        && (!data.keys().hasAny(['imageUrl']) || (data.imageUrl is string && data.imageUrl.size() <= 1048000))
        && (!data.keys().hasAny(['instagram']) || (data.instagram is string && data.instagram.size() <= 200))
        && (!data.keys().hasAny(['twitter']) || (data.twitter is string && data.twitter.size() <= 200))
        && (!data.keys().hasAny(['likesCount']) || data.likesCount is number);
    }

    function isValidReferral(data) {
      return data.keys().hasAll(['creatorId', 'introducerName', 'reason', 'conversationCount', 'createdAt'])
        && data.creatorId is string && data.creatorId.size() <= 128
        && data.introducerName is string && data.introducerName.size() <= 200
        && data.reason is string && data.reason.size() <= 2000
        && data.conversationCount is number
        && data.createdAt is timestamp
        && (!data.keys().hasAny(['introducerContact']) || (data.introducerContact is string && data.introducerContact.size() <= 200))
        && (!data.keys().hasAny(['icebreakers']) || data.icebreakers is list);
    }

    function isValidMediaContent(data) {
      return data.keys().hasAll(['title', 'youtubeUrl', 'createdAt'])
        && data.title is string && data.title.size() <= 500
        && data.youtubeUrl is string && data.youtubeUrl.size() <= 1000
        && data.createdAt is timestamp
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 5000))
        && (!data.keys().hasAny(['likesCount']) || data.likesCount is number)
        && (!data.keys().hasAny(['tipsCount']) || data.tipsCount is number)
        && (!data.keys().hasAny(['tipsTotalYen']) || data.tipsTotalYen is number);
    }

    function isValidTipTransaction(data) {
      return data.keys().hasAll(['contentId', 'amount', 'backerName', 'createdAt'])
        && data.contentId is string && data.contentId.size() <= 128
        && data.amount is number
        && data.backerName is string && data.backerName.size() <= 200
        && data.createdAt is timestamp
        && (!data.keys().hasAny(['cheerMessage']) || (data.cheerMessage is string && data.cheerMessage.size() <= 1000));
    }

    // --- COLLECTION RULES ---
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      // Allow admins to do everything
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      
      // Allow public to increment or decrement likesCount, but ONLY that field
      allow update: if (isAdmin() && isValidEvent(incoming()))
                      || (isValidId(eventId) && 
                          incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) &&
                          (incoming().likesCount == (existing().get('likesCount', 0) + 1) ||
                           (incoming().likesCount == (existing().get('likesCount', 0) - 1) && incoming().likesCount >= 0)));
      
      allow delete: if isAdmin() && isValidId(eventId);

      match /likes/{likeId} {
        allow read: if true;
        // Public can create a like if it's the correct format
        allow create: if isValidId(likeId) && isValidLike(incoming(), likeId);
        // Allow delete for toggle functionality
        allow delete: if isValidId(likeId);
      }
    }

    match /analytics_visits/{visitId} {
      allow read: if isAdmin();
      // Relax visitId check to support sessionId-based format (date_deviceId_sessionId)
      allow create: if isValidVisit(incoming()) && visitId.size() <= 128;
      // Allow updates to duration and scroll depth for non-admins
      allow update: if isAdmin() || (
        isValidVisit(incoming()) && 
        incoming().diff(existing()).affectedKeys().hasAny(['duration', 'maxScrollDepth', 'lastActive'])
      );
      allow delete: if isAdmin();
    }

    match /analytics_actions/{actionId} {
      allow read: if isAdmin();
      allow create: if isValidAction(incoming());
      allow update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isValidFeedback(incoming());
      allow update, delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(imageId) && isValidGalleryImage(incoming());
      allow delete: if isAdmin() && isValidId(imageId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow delete: if isAdmin() && isValidId(productId);
    }

    match /creators/{creatorId} {
      allow read: if true;
      allow create, delete: if isAdmin() && isValidId(creatorId);
      allow update: if (isAdmin() && isValidCreatorCard(incoming()))
                      || (isValidId(creatorId) && 
                          incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) &&
                          (incoming().likesCount == (existing().get('likesCount', 0) + 1) ||
                           (incoming().likesCount == (existing().get('likesCount', 0) - 1) && incoming().likesCount >= 0)));
    }

    match /referrals/{referralId} {
      allow read: if true;
      allow create: if isValidId(referralId) && isValidReferral(incoming());
      allow update: if (isAdmin() && isValidReferral(incoming()))
                      || (isValidId(referralId) && 
                          incoming().diff(existing()).affectedKeys().hasOnly(['conversationCount']) &&
                          incoming().conversationCount == (existing().get('conversationCount', 0) + 1));
      allow delete: if isAdmin() && isValidId(referralId);
    }

    match /media/{mediaId} {
      allow read: if true;
      allow create, delete: if isAdmin() && isValidId(mediaId);
      allow update: if (isAdmin() && isValidMediaContent(incoming()))
                      || (isValidId(mediaId) && 
                          incoming().diff(existing()).affectedKeys().hasAny(['likesCount', 'tipsCount', 'tipsTotalYen']));

      match /tips/{tipId} {
        allow read: if true;
        allow create: if isValidId(tipId) && isValidTipTransaction(incoming());
        allow update, delete: if isAdmin();
      }
    }
  }
}
