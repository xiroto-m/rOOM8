rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email.lower() == "hiroto.mizutani@gmail.com" || 
         request.auth.token.email.lower() == "taku448@gmail.com") &&
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY VALIDATIONS ---
    function isValidEvent(data) {
      return data.keys().hasAll(['date', 'time', 'locationName', 'address', 'access', 'fee', 'googleMapEmbedUrl', 'order', 'updatedAt'])
        && data.date is string && data.date.size() <= 100
        && data.time is string && data.time.size() <= 100
        && data.locationName is string && data.locationName.size() <= 200
        && data.address is string && data.address.size() <= 300
        && data.access is string && data.access.size() <= 300
        && data.fee is string && data.fee.size() <= 100
        && data.googleMapEmbedUrl is string && data.googleMapEmbedUrl.size() <= 1000
        && (!data.keys().hasAny(['youtubeUrl']) || (data.youtubeUrl is string && data.youtubeUrl.size() <= 1000))
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 10000))
        && (!data.keys().hasAny(['title']) || (data.title is string && data.title.size() <= 200))
        && (!data.keys().hasAny(['likesCount']) || data.likesCount is number)
        && data.order is number
        && data.updatedAt is timestamp;
    }

    function isValidLike(data, likeId) {
      return data.keys().hasAll(['ip', 'eventId', 'createdAt'])
        && data.ip is string && data.ip.size() <= 64
        && likeId == data.ip
        && data.eventId is string && data.eventId.size() <= 128
        && data.createdAt == request.time;
    }

    function isValidVisit(data, visitId) {
      let expectedId = data.date + '_' + data.deviceId;
      return data.keys().hasAll(['deviceId', 'ip', 'date', 'deviceType', 'userAgent', 'timestamp'])
        && data.deviceId is string && data.deviceId.size() <= 128
        && data.ip is string && data.ip.size() <= 64
        && data.date is string && data.date.size() <= 10
        && data.deviceType in ['mobile', 'desktop']
        && visitId == expectedId
        && data.timestamp == request.time;
    }

    function isValidAction(data) {
      return data.keys().hasAll(['actionType', 'deviceId', 'date', 'timestamp'])
        && data.actionType is string && data.actionType.size() <= 100
        && data.deviceId is string && data.deviceId.size() <= 128
        && data.date is string && data.date.size() <= 10
        && data.timestamp == request.time;
    }

    // --- COLLECTION RULES ---
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      // Allow admins to do everything
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      
      // Allow public to increment or decrement likesCount, but ONLY that field
      allow update: if (isAdmin() && isValidEvent(incoming()))
                      || (isValidId(eventId) && 
                          incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) &&
                          (incoming().likesCount == (existing().get('likesCount', 0) + 1) ||
                           (incoming().likesCount == (existing().get('likesCount', 0) - 1) && incoming().likesCount >= 0)));
      
      allow delete: if isAdmin() && isValidId(eventId);

      match /likes/{likeId} {
        allow read: if true;
        // Public can create a like if it's the correct format
        allow create: if isValidId(likeId) && isValidLike(incoming(), likeId);
        // Allow delete for toggle functionality
        allow delete: if isValidId(likeId);
      }
    }

    match /analytics_visits/{visitId} {
      allow read: if isAdmin();
      allow create: if isValidVisit(incoming(), visitId);
      allow update, delete: if isAdmin();
    }

    match /analytics_actions/{actionId} {
      allow read: if isAdmin();
      allow create: if isValidAction(incoming());
      allow update, delete: if isAdmin();
    }

    match /analytics_daily_stats/{date} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
