{
  "entities": {
    "EventConfig": {
      "title": "Event Configuration",
      "description": "Configuration data for an event",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "time": { "type": "string" },
        "locationName": { "type": "string" },
        "address": { "type": "string" },
        "access": { "type": "string" },
        "fee": { "type": "string" },
        "googleMapEmbedUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "order": { "type": "number" },
        "likesCount": { "type": "number" },
        "youtubeUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "date",
        "time",
        "locationName",
        "address",
        "access",
        "fee",
        "googleMapEmbedUrl",
        "updatedAt"
      ]
    },
    "Like": {
      "title": "Like",
      "description": "A like from a specific IP address",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "eventId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ip", "eventId", "createdAt"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A unique daily visit from an IP",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["ip", "date", "timestamp"]
    },
    "DailyStats": {
      "title": "Daily Stats",
      "description": "Aggregated daily stats",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "count": { "type": "number" }
      },
      "required": ["date", "count"]
    }
  },
  "firestore": {
    "/settings/event_info": {
      "schema": "EventConfig",
      "description": "Legacy single document containing current event settings (fallback)"
    },
    "/events/{eventId}": {
      "schema": "EventConfig",
      "description": "Collection of upcoming events"
    },
    "/events/{eventId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes for a specific event, keyed by a value derived from IP"
    },
    "/analytics_visits/{visitId}": {
      "schema": "Visit",
      "description": "Daily unique IP visits"
    },
    "/analytics_daily_stats/{date}": {
      "schema": "DailyStats",
      "description": "Aggregated stats by date"
    }
  }
}
