{
  "entities": {
    "EventConfig": {
      "title": "Event Configuration",
      "description": "Configuration data for an event",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "time": { "type": "string" },
        "endTime": { "type": "string" },
        "locationName": { "type": "string" },
        "address": { "type": "string" },
        "access": { "type": "string" },
        "fee": { "type": "string" },
        "googleMapEmbedUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "order": { "type": "number" },
        "likesCount": { "type": "number" },
        "youtubeUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "date",
        "time",
        "locationName",
        "address",
        "access",
        "fee",
        "googleMapEmbedUrl",
        "updatedAt"
      ]
    },
    "Like": {
      "title": "Like",
      "description": "A like from a specific IP address",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "eventId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ip", "eventId", "createdAt"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A session visit from a device",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string" },
        "ip": { "type": "string" },
        "date": { "type": "string" },
        "deviceType": { "type": "string", "enum": ["mobile", "desktop"] },
        "userAgent": { "type": "string" },
        "language": { "type": "string" },
        "screenWidth": { "type": "number" },
        "screenHeight": { "type": "number" },
        "pixelRatio": { "type": "number" },
        "orientation": { "type": "string" },
        "isInAppBrowser": { "type": "boolean" },
        "inAppType": { "type": "string" },
        "connectionType": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "maxScrollDepth": { "type": "number" },
        "sectionsReached": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["deviceId", "date", "timestamp"]
    },
    "Action": {
      "title": "Action",
      "description": "A user interaction or click tracking",
      "type": "object",
      "properties": {
        "actionType": { "type": "string" },
        "deviceId": { "type": "string" },
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "eventId": { "type": "string" },
        "title": { "type": "string" }
      },
      "required": ["actionType", "deviceId", "date", "timestamp"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "An image uploaded to the privacy gallery",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "createdAt": { "type": "number" },
        "order": { "type": "number" }
      },
      "required": ["url", "createdAt", "order"]
    }
  },
  "firestore": {
    "/settings/event_info": {
      "schema": "EventConfig",
      "description": "Legacy single document containing current event settings (fallback)"
    },
    "/events/{eventId}": {
      "schema": "EventConfig",
      "description": "Collection of upcoming events"
    },
    "/events/{eventId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes for a specific event, keyed by a value derived from IP"
    },
    "/analytics_visits/{visitId}": {
      "schema": "Visit",
      "description": "User session logs (one document per browser session)"
    },
    "/analytics_actions/{actionId}": {
      "schema": "Action",
      "description": "User interaction logs"
    },
    "/gallery/{imageId}": {
      "schema": "GalleryImage",
      "description": "Gallery images"
    }
  }
}
