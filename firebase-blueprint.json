{
  "entities": {
    "EventConfig": {
      "title": "Event Configuration",
      "description": "Configuration data for an event",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "time": { "type": "string" },
        "endTime": { "type": "string" },
        "locationName": { "type": "string" },
        "address": { "type": "string" },
        "access": { "type": "string" },
        "fee": { "type": "string" },
        "googleMapEmbedUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "order": { "type": "number" },
        "likesCount": { "type": "number" },
        "youtubeUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "date",
        "time",
        "locationName",
        "address",
        "access",
        "fee",
        "googleMapEmbedUrl",
        "updatedAt"
      ]
    },
    "Like": {
      "title": "Like",
      "description": "A like from a specific IP address",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "eventId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ip", "eventId", "createdAt"]
    },
    "Visit": {
      "title": "Visit",
      "description": "A session visit from a device",
      "type": "object",
      "properties": {
        "deviceId": { "type": "string" },
        "ip": { "type": "string" },
        "date": { "type": "string" },
        "deviceType": { "type": "string", "enum": ["mobile", "desktop"] },
        "userAgent": { "type": "string" },
        "language": { "type": "string" },
        "screenWidth": { "type": "number" },
        "screenHeight": { "type": "number" },
        "pixelRatio": { "type": "number" },
        "orientation": { "type": "string" },
        "isInAppBrowser": { "type": "boolean" },
        "inAppType": { "type": "string" },
        "connectionType": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "number" },
        "maxScrollDepth": { "type": "number" },
        "sectionsReached": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["deviceId", "date", "timestamp"]
    },
    "Action": {
      "title": "Action",
      "description": "A user interaction or click tracking",
      "type": "object",
      "properties": {
        "actionType": { "type": "string" },
        "deviceId": { "type": "string" },
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "eventId": { "type": "string" },
        "title": { "type": "string" }
      },
      "required": ["actionType", "deviceId", "date", "timestamp"]
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "An image uploaded to the privacy gallery",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "createdAt": { "type": "number" },
        "order": { "type": "number" }
      },
      "required": ["url", "createdAt", "order"]
    },
    "Product": {
      "title": "Product",
      "description": "Artwork or goods for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "currency": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold_out", "hidden"] },
        "stripePriceId": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "currency", "status", "createdAt"]
    },
    "CreatorCard": {
      "title": "Creator Card",
      "description": "Profile card for a creator, artist, or interesting person at rOOM8",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "instagram": { "type": "string" },
        "twitter": { "type": "string" },
        "likesCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "specialty", "bio", "createdAt"]
    },
    "Referral": {
      "title": "Referral Record",
      "description": "A customized referral/other-recommendation card crafted by an introducer for a creator",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "introducerName": { "type": "string" },
        "introducerContact": { "type": "string" },
        "reason": { "type": "string" },
        "icebreakers": { "type": "array", "items": { "type": "string" } },
        "conversationCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["creatorId", "introducerName", "reason", "conversationCount", "createdAt"]
    },
    "MediaContent": {
      "title": "Media Content",
      "description": "Vibey party videos or artwork process explanations on feed",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "youtubeUrl": { "type": "string" },
        "likesCount": { "type": "number" },
        "tipsCount": { "type": "number" },
        "tipsTotalYen": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "youtubeUrl", "createdAt"]
    },
    "TipTransaction": {
      "title": "Tip Transaction",
      "description": "A support/cheer points tipping transaction for a media post",
      "type": "object",
      "properties": {
        "contentId": { "type": "string" },
        "amount": { "type": "number" },
        "backerName": { "type": "string" },
        "cheerMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["contentId", "amount", "backerName", "createdAt"]
    },
    "LostItem": {
      "title": "Lost Item Artwork",
      "description": "Lost and found items exhibited as art pieces on the site",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "foundDate": { "type": "string" },
        "frameStyle": { "type": "string", "enum": ["gold", "wood", "brutalist", "neon", "none"] },
        "status": { "type": "string", "enum": ["exhibiting", "claimed", "archived"] },
        "likesCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "artist", "description", "imageUrl", "foundDate", "frameStyle", "status", "createdAt"]
    }
  },
  "firestore": {
    "/settings/event_info": {
      "schema": "EventConfig",
      "description": "Legacy single document containing current event settings (fallback)"
    },
    "/events/{eventId}": {
      "schema": "EventConfig",
      "description": "Collection of upcoming events"
    },
    "/events/{eventId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes for a specific event, keyed by a value derived from IP"
    },
    "/analytics_visits/{visitId}": {
      "schema": "Visit",
      "description": "User session logs (one document per browser session)"
    },
    "/analytics_actions/{actionId}": {
      "schema": "Action",
      "description": "User interaction logs"
    },
    "/gallery/{imageId}": {
      "schema": "GalleryImage",
      "description": "Gallery images"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Products available in the shop"
    },
    "/creators/{creatorId}": {
      "schema": "CreatorCard",
      "description": "Profiles of creators, artists and interesting people at rOOM8"
    },
    "/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Introductory recommendation references scanning QR codes at the party"
    },
    "/media/{mediaId}": {
      "schema": "MediaContent",
      "description": "Party video feeds and explanatory digital exhibits"
    },
    "/media/{mediaId}/tips/{tipId}": {
      "schema": "TipTransaction",
      "description": "Tip transactions showing public support and cheerful notes"
    },
    "/lost_items/{itemId}": {
      "schema": "LostItem",
      "description": "Lost and found items exhibited creatively with custom picture frames"
    }
  }
}
